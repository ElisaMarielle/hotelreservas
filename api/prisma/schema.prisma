generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model Quartos {
  id      Int      @id @default(autoincrement())
  numero  String
  tipo    Tipo @default(STANDARD)
  reserva Reservas[]
}

model Reservas {
  id           Int      @id @default(autoincrement())
  hospede      String
  data_entrada DateTime @default(now())
  data_saida   DateTime
  quartos      Quartos?  @relation(fields: [quartosId], references: [id])
  quartosId    Int?
}

enum Tipo {
  STANDARD
  LUXO
  SUITE
}
